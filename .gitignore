# KairosAI — .gitignore

# ------------------------------------------------------------------
# Secrets (NEVER commit)
# ------------------------------------------------------------------
.env
*.key
*.pem

# ------------------------------------------------------------------
# Python
# ------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
kenv/
.env_
env/
.Python
pip-log.txt

# ------------------------------------------------------------------
# Node / Frontend
# ------------------------------------------------------------------
node_modules/
.npm
frontend/dist/
frontend/.vite/
*.local

# ------------------------------------------------------------------
# Generated output (keep .gitkeep)
# ------------------------------------------------------------------
logs/*.log
logs/*.jsonl
reports/*.json
reports/*.md
!logs/.gitkeep
!reports/.gitkeep

backend/reports/*.json
backend/reports/*.md
backend/logs/*.jsonl
backend/logs/*.log

# ------------------------------------------------------------------
# OS / Editor
# ------------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ------------------------------------------------------------------
# Docker
# ------------------------------------------------------------------
*.override.yml