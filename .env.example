# KairosAI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to git.

# ------------------------------------------------------------------
# LLM API
# ------------------------------------------------------------------
GROQ_API_KEY = ****
# Model — llama-3.3-70b-versatile is free, fast, 128k context
GROQ_MODEL=llama-3.3-70b-versatile
# Model to use (do not change unless you know what you're doing)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ------------------------------------------------------------------
# Backend server
# ------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO

# ------------------------------------------------------------------
# Frontend
# ------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws

# ------------------------------------------------------------------
# Output paths
# ------------------------------------------------------------------
REPORTS_DIR=./reports
LOGS_DIR=./logs
